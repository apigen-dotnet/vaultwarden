    "/connect/token": {
      "post": {
        "tags": [
          "Connect"
        ],
        "summary": "Exchange credentials for an access token (OAuth2 password or client_credentials grant)",
        "operationId": "Connect_Token",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "required": [
                  "grant_type",
                  "client_id"
                ],
                "type": "object",
                "properties": {
                  "grant_type": {
                    "enum": [
                      "password",
                      "client_credentials"
                    ],
                    "type": "string",
                    "description": "OAuth2 grant type: \u0027password\u0027 or \u0027client_credentials\u0027"
                  },
                  "username": {
                    "type": "string",
                    "description": "Email address (for password grant)"
                  },
                  "password": {
                    "type": "string",
                    "description": "Base64-encoded master password hash (for password grant)"
                  },
                  "scope": {
                    "type": "string",
                    "description": "Requested scopes, e.g. \u0027api offline_access\u0027"
                  },
                  "client_id": {
                    "type": "string",
                    "description": "Client identifier: \u0027cli\u0027, \u0027web\u0027, \u0027browser\u0027, \u0027desktop\u0027, \u0027mobile\u0027, or an API key client_id"
                  },
                  "client_secret": {
                    "type": "string",
                    "description": "Client secret (for client_credentials grant with API key)"
                  },
                  "deviceType": {
                    "type": "integer",
                    "description": "Device type enum: 9=CLI, 6=WindowsDesktop, 7=MacOsDesktop, etc.",
                    "format": "int32"
                  },
                  "deviceIdentifier": {
                    "type": "string",
                    "description": "Unique device GUID"
                  },
                  "deviceName": {
                    "type": "string",
                    "description": "Device name string, e.g. \u0027cli\u0027"
                  },
                  "devicePushToken": {
                    "type": "string",
                    "description": "Push notification token (empty for CLI)"
                  },
                  "twoFactorToken": {
                    "type": "string",
                    "description": "2FA code (TOTP, YubiKey, etc.)"
                  },
                  "twoFactorProvider": {
                    "type": "integer",
                    "description": "2FA provider: 0=Authenticator, 1=Email, 2=Duo, 3=YubiKey, 5=Remember, 7=WebAuthn",
                    "format": "int32"
                  },
                  "twoFactorRemember": {
                    "type": "integer",
                    "description": "Set to 1 to remember this device for 2FA",
                    "format": "int32"
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful authentication",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Authentication failed (invalid credentials, 2FA required, etc.)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
